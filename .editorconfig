# EditorConfig — https://editorconfig.org
root = true

# ──── 공통 기본값 ────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# ──── Python ─────────────────────────────────────────────────
# ruff / black 기준: indent 4, max line 100
[*.py]
indent_style = space
indent_size  = 4
max_line_length = 100

# ──── TypeScript / JavaScript / JSON / CSS ───────────────────
# Prettier 기준: indent 2, printWidth 100
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size  = 2
max_line_length = 100

[*.{json,jsonc}]
indent_style = space
indent_size  = 2

[*.css]
indent_style = space
indent_size  = 2

# ──── 마크업 / 설정 파일 ─────────────────────────────────────
[*.{yaml,yml,toml}]
indent_style = space
indent_size  = 2

[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size  = 2

# ──── 배치 / 셸 스크립트 ────────────────────────────────────
[*.{bat,cmd}]
end_of_line = crlf

[*.{sh,ps1}]
end_of_line = lf
